{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DragonFruit",
  "version": "0.1.0",
  "identifier": "org.openresinalliance.dragonfruit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri",
    "devUrl": "http://localhost:3005",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DragonFruit",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  }
}
